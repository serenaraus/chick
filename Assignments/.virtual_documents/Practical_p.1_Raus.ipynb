from pathlib import Path

folder = Path(r"C:\Users\seren\Documents\GitHub\chick\QuaQua")

py_count = 0
ipynb_count = 0
md_count = 0

for path in folder.glob("*"):
    if path.suffix == ".py":
        py_count += 1
    elif path.suffix == ".ipynb":
        ipynb_count += 1
    elif path.suffix == ".md":
        md_count += 1

print("py:", py_count)
print("ipynb:", ipynb_count)
print("md:", md_count)





