def multiply_values(numbers, coeff=2):
    """Multiply all values in a list by a coefficient"""
    for i in range(len(numbers)):
        numbers[i] = numbers[i] * coeff
    return numbers

print(f"List with wrong code: {list_of_vals}")
double_vals = multiply_values(list_of_vals, 2)
print(double_vals, list_of_vals)
triple_vals = multiply_values(list_of_vals, 3)
print(triple_vals, list_of_vals)

# Rewrite the function below:
def multiply_values_fixed(numbers, coeff=2):
    new_numbers = []
    for value in numbers:
        new_numbers.append(value * coeff)
    return new_numbers

# prints with fixed code
new_list_of_vals = [1, 2, 3]
print(f"List with new code: {new_list_of_vals}")
double_vals = multiply_values_fixed(new_list_of_vals, 2)
print(double_vals, new_list_of_vals)
triple_vals = multiply_values_fixed(new_list_of_vals, 3)
print(triple_vals, new_list_of_vals)





