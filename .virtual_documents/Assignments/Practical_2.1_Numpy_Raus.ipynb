a = np.array([1, 2, 3, 4, 5, 6])

# First: reproduce the view behavior
b = a[1:5]
b[0] = 99
print(a)
print(b)

# Then: create an independent copy and modify it
a2 = np.array([1, 2, 3, 4, 5, 6])
b2 = a2[1:5].copy()
b2[0] = 99
print(a2)
print(b2)





