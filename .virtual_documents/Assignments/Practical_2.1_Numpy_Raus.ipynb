data = np.random.randint(-5, 10, size=(4, 5))

data = data.astype(float)
data[data < 0] = np.nan

print(data)
print(data.shape)
print(data.dtype)
print(data.size)

last_two_cols = data[:, -2:]
non_negative = data[~np.isnan(data)]

print(last_two_cols)
print(non_negative)






# Option A
v = np.array([-2, 3, -1, 5, 0, 4])
positive_list = []
for x in v:
    if x > 0:
        positive_list.append(x)
positive_a = np.array(positive_list)

# Option B
v = np.array([-2, 3, -1, 5, 0, 4])
positive_b = v[v > 0]

print(positive_a)
print(positive_b)

# Same values?
print(np.array_equal(positive_a,positive_b))

